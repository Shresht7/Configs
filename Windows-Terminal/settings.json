{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [
        {
            "command": {
                "action": "scrollToMark",
                "direction": "previous"
            },
            "id": "User.ScrollToMark.Prev"
        },
        {
            "command": {
                "action": "scrollToMark",
                "direction": "next"
            },
            "id": "User.ScrollToMark.Next"
        },
        {
            "command": "tabSearch",
            "id": "User.TabSearch"
        }
    ],
    "alwaysShowNotificationIcon": false,
    "centerOnLaunch": true,
    "compatibility.allowHeadless": true,
    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "initialRows": 30,
    "keybindings": [
        {
            "id": "Terminal.CopyFromClipboard",
            "keys": "ctrl+c"
        },
        {
            "id": "Terminal.OpenNewTab",
            "keys": "ctrl+t"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+v"
        },
        {
            "id": "Terminal.FindText",
            "keys": "ctrl+shift+f"
        },
        {
            "id": "User.TabSearch",
            "keys": "ctrl+4"
        },
        {
            "id": "Terminal.PrevTab",
            "keys": "ctrl+pgup"
        },
        {
            "id": "Terminal.DuplicatePaneAuto",
            "keys": "ctrl+shift+t"
        },
        {
            "id": "Terminal.SplitPaneUp",
            "keys": "ctrl+alt+up"
        },
        {
            "id": "Terminal.SplitPaneDown",
            "keys": "ctrl+alt+down"
        },
        {
            "id": "Terminal.SplitPaneRight",
            "keys": "ctrl+alt+right"
        },
        {
            "id": "Terminal.SplitPaneLeft",
            "keys": "ctrl+alt+left"
        },
        {
            "id": "Terminal.NextTab",
            "keys": "ctrl+pgdn"
        },
        {
            "id": "Terminal.SwapPaneUp",
            "keys": "ctrl+shift+alt+up"
        },
        {
            "id": "Terminal.SwapPaneDown",
            "keys": "ctrl+shift+alt+down"
        },
        {
            "id": "Terminal.SwapPaneRight",
            "keys": "ctrl+shift+alt+right"
        },
        {
            "id": "Terminal.SwapPaneLeft",
            "keys": "ctrl+shift+alt+left"
        },
        {
            "id": "Terminal.ClosePane",
            "keys": "ctrl+w"
        },
        {
            "id": "Terminal.ToggleFocusMode",
            "keys": "shift+f11"
        },
        {
            "id": "Terminal.TogglePaneZoom",
            "keys": "alt+f11"
        },
        {
            "id": "Terminal.ToggleAlwaysOnTop",
            "keys": "ctrl+shift+f11"
        },
        {
            "id": "User.ScrollToMark.Prev",
            "keys": "ctrl+up"
        },
        {
            "id": "User.ScrollToMark.Next",
            "keys": "ctrl+down"
        }
    ],
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": {
        "defaults": {
            "autoMarkPrompts": true,
            "colorScheme": {
                "dark": "S7",
                "light": "Frost"
            },
            "font": {
                "face": "JetBrainsMono NF",
                "size": 10
            },
            "opacity": 50,
            "experimental.rightClickContextMenu": true,
            "showMarksOnScrollbar": true,
            "useAcrylic": true
        },
